{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axos Creative Genome v8.0 (Cloud)",
  "type": "object",
  "properties": {
    "production_constraints": {
      "type": "object",
      "properties": {
        "max_shot_duration": { "type": "number", "const": 8.0 },
        "frame_rate_policy": { "type": "string", "const": "NTSC_29_97" },
        "truncation_offset": { "type": "number", "const": -0.1 },
        "resolution": { "type": "string", "const": "4K_16_9" }
      }
    },
    "compliance": {
      "ssot_injection_keys": { "type": "array", "items": { "type": "string" } },
      "demographic_exclusion_flag": { "type": "boolean", "const": true }
    }
  }
}